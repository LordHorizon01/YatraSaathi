# ─── Required ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...

# ─── Optional (leave blank to run without Redis — in-memory fallback used) ────
REDIS_URL=redis://localhost:6379/0

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, zero-config):
DATABASE_URL=sqlite+aiosqlite:///./saarthi.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/saarthi

# ─── App Config ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
DANGER_BUBBLE_RADIUS_KM=1.0
DANGER_BUBBLE_TTL_SEC=30
